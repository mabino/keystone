#!/usr/bin/env zsh

# Capture script source path as early as possible
SOURCE_FILE="${(%):-%x}"

# Keystone: Private Key Manager
# https://github.com/mabino/keystone

# Colors
export BLUE='\033[0;34m'
export GREEN='\033[0;32m'
export RED='\033[0;31m'
export YELLOW='\033[1;33m'
export CYAN='\033[0;36m'
export NC='\033[0m' # No Color
export BOLD='\033[1m'

ICLOUD_PATH="$HOME/Library/Mobile Documents/com~apple~CloudDocs"
DMG_NAME="keystone.dmg"
DMG_PATH="$ICLOUD_PATH/$DMG_NAME"
MOUNT_POINT="/Volumes/Keystone"
INSTALL_PATH="${XDG_BIN_HOME:-$HOME/.local/bin}/keystone"

# --- Utility Functions ---

wait_for_key() {
    if [[ -z "$CLI_MODE" ]]; then
        echo -ne "\n${CYAN}Press any key to return to menu...${NC}"
        read -k 1 -s
    fi
}

print_help() {
    echo -e "${CYAN}${BOLD}🔑 KEYSTONE: Private Key Manager${NC}"
    echo -e "Usage: keystone [options]"
    echo ""
    echo -e "${BOLD}Options:${NC}"
    echo -e "  -h, --help      Show this help message"
    echo -e "  --install       Install keystone to ~/.local/bin"
    echo -e "  --remove        Uninstall keystone from ~/.local/bin"
    echo -e "  --list          List stored keys"
    echo -e "  --pack          Pack local keys to iCloud"
    echo -e "  --restore       Restore keys to this device"
    echo -e "  --wipe          Wipe stored keys (Dangerous!)"
    echo ""
    echo -e "${BOLD}Examples:${NC}"
    echo -e "  keystone        (Launch interactive menu)"
    echo -e "  keystone --pack (Run pack and exit)"
}

install_keystone() {
    echo -e "${YELLOW}Installing Keystone...${NC}"
    mkdir -p "$(dirname "$INSTALL_PATH")" || { echo -e "${RED}Error: Failed to create directory $(dirname "$INSTALL_PATH")${NC}"; exit 1; }
    
    if [[ -f "$SOURCE_FILE" && "$SOURCE_FILE" != "zsh" && "$SOURCE_FILE" != "sh" ]]; then
        cp "$SOURCE_FILE" "$INSTALL_PATH" || { echo -e "${RED}Error: Failed to copy $SOURCE_FILE to $INSTALL_PATH${NC}"; exit 1; }
    else
        # Piped installation fallback (e.g., curl | zsh)
        echo -e "${YELLOW}Installing from GitHub (Cache-busting)...${NC}"
        local remote_url="https://raw.githubusercontent.com/mabino/keystone/main/keystone?cb=$(date +%s)"
        if command -v curl >/dev/null; then
            curl -fsSL "$remote_url" -o "$INSTALL_PATH" || { echo -e "${RED}Error: Failed to download Keystone${NC}"; exit 1; }
        elif command -v wget >/dev/null; then
            wget -qO "$INSTALL_PATH" "$remote_url" || { echo -e "${RED}Error: Failed to download Keystone${NC}"; exit 1; }
        else
            echo -e "${RED}Error: Cannot install from pipe without curl or wget.${NC}"
            exit 1
        fi
    fi

    chmod +x "$INSTALL_PATH" || { echo -e "${RED}Error: Failed to make $INSTALL_PATH executable${NC}"; exit 1; }
    echo -e "${GREEN}Keystone installed to $INSTALL_PATH${NC}"
    exit 0
}

remove_keystone() {
    echo -e "${RED}Uninstalling Keystone...${NC}"
    rm -f "$INSTALL_PATH"
    echo -e "${GREEN}Keystone removed.${NC}"
    exit 0
}

print_header() {
    clear
    echo -e "${CYAN}${BOLD}🔑 KEYSTONE: Private Key Manager (v1.5-PROACTIVE)${NC}"
    echo -e "${CYAN}Build Time: $(date +'%Y-%m-%d %H:%M:%S')${NC}"
    echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}\n"
}

check_status() {
    echo -e "${BOLD}Current Status:${NC}"
    
    # 1. iCloud Drive
    if [[ -d "$ICLOUD_PATH" ]]; then
        echo -e "  [${GREEN}✓${NC}] iCloud Drive: ${GREEN}Mounted${NC}"
    else
        echo -e "  [${RED}✗${NC}] iCloud Drive: ${RED}Not Found${NC}"
    fi

    # 2. Encrypted DMG
    if [[ -f "$DMG_PATH" ]]; then
        echo -e "  [${GREEN}✓${NC}] Encrypted DMG: ${GREEN}Detected${NC} ($DMG_NAME)"
    else
        echo -e "  [${YELLOW}!${NC}] Encrypted DMG: ${YELLOW}Missing${NC}"
    fi

    # 3. Keychain Status
    if security find-generic-password -s "$DMG_NAME" > /dev/null 2>&1; then
        echo -e "  [${GREEN}✓${NC}] Apple Keychain: ${GREEN}Passphrase Found${NC}"
    else
        echo -e "  [${YELLOW}!${NC}] Apple Keychain: ${YELLOW}Passphrase Not Stored${NC}"
    fi

    # 4. Mount Status
    if [[ -d "$MOUNT_POINT" ]]; then
        echo -e "  [${GREEN}✓${NC}] DMG State: ${GREEN}Unlocked & Mounted${NC}"
    else
        echo -e "  [${YELLOW}○${NC}] DMG State: ${YELLOW}Locked${NC}"
    fi
    echo ""
}

# --- Authentication ---

authenticate() {
    echo -e "${YELLOW}Authenticating with Touch ID...${NC}"
    swift -e '
import LocalAuthentication
let context = LAContext()
var error: NSError?
if context.canEvaluatePolicy(.deviceOwnerAuthenticationWithBiometrics, error: &error) {
    let semaphore = DispatchSemaphore(value: 0)
    var success = false
    context.evaluatePolicy(.deviceOwnerAuthenticationWithBiometrics, localizedReason: "Unlock Keystone") { (s, e) in
        success = s
        semaphore.signal()
    }
    semaphore.wait()
    exit(success ? 0 : 1)
} else {
    exit(0) 
}'
    local AUTH_STATUS=$?
    if [[ $AUTH_STATUS -ne 0 ]]; then
        echo -e "${RED}Authentication failed.${NC}"
        return 1
    fi
    echo -e "${GREEN}Authentication successful.${NC}"
    return 0
}

init_dmg() {
    echo -e "${YELLOW}Creating new encrypted DMG (Read/Write)...${NC}"
    mkdir -p /tmp/keystone_tmp
    # We let hdiutil prompt for the password so the user can confirm it (asks twice)
    if hdiutil create -size 10m -fs HFS+ -volname Keystone -encryption AES-256 -srcfolder /tmp/keystone_tmp -format UDRW "$DMG_PATH"; then
        rm -rf /tmp/keystone_tmp
        echo -e "${GREEN}DMG created at $DMG_PATH${NC}"
        echo -e "${CYAN}Note: You will be prompted for this passphrase again to mount it and save it to your Keychain.${NC}"
        return 0
    else
        rm -rf /tmp/keystone_tmp
        echo -e "${RED}Failed to create DMG.${NC}"
        return 1
    fi
}

mount_dmg() {
    if [[ -d "$MOUNT_POINT" ]]; then
        echo -e "${GREEN}Keystone is already unlocked and mounted.${NC}"
        return 0
    fi
    
    if [[ ! -f "$DMG_PATH" ]]; then
        echo -e "${YELLOW}Encrypted DMG not found at $DMG_PATH${NC}"
        echo -ne "${CYAN}Would you like to create a new one now? (y/N) ${NC}"
        read -k 1 create_choice
        echo ""
        if [[ "$create_choice" == "y" ]]; then
            init_dmg || return 1
        else
            return 1
        fi
    fi

    if ! authenticate; then return 1; fi

    echo -e "${YELLOW}Unlocking Keystone DMG...${NC}"
    
    local hdi_status=1
    if security find-generic-password -s "$DMG_NAME" >/dev/null 2>&1; then
        echo -e "${CYAN}Extracting passphrase from Apple Keychain...${NC}"
        local pass
        pass=$(security find-generic-password -s "$DMG_NAME" -w 2>/dev/null)
        
        if [[ -n "$pass" ]]; then
            # Try to attach using the extracted password
            printf "%s" "$pass" | hdiutil attach "$DMG_PATH" -mountpoint "$MOUNT_POINT" -stdinpass >/dev/null 2>&1
            hdi_status=$?
            
            if [[ $hdi_status -ne 0 ]]; then
                echo -e "${RED}Keychain passphrase failed authentication.${NC}"
                security delete-generic-password -s "$DMG_NAME" >/dev/null 2>&1
            fi
        fi
    fi

    # Manual Fallback / First Time
    if [[ $hdi_status -ne 0 ]]; then
        echo -e "${YELLOW}Manual passphrase entry required.${NC}"
        echo -ne "${BOLD}Enter Passphrase for Keystone DMG: ${NC}"
        read -r -s passphrase
        echo ""
        
        if [[ -z "$passphrase" ]]; then
            echo -e "${RED}Error: Passphrase cannot be empty.${NC}"
            return 1
        fi

        echo -e "${CYAN}Testing passphrase...${NC}"
        printf "%s" "$passphrase" | hdiutil attach "$DMG_PATH" -mountpoint "$MOUNT_POINT" -stdinpass >/dev/null 2>&1
        hdi_status=$?
        
        if [[ $hdi_status -eq 0 ]]; then
            echo -e "${GREEN}Success!${NC}"
            echo -ne "\n${CYAN}Would you like to keep this passphrase in your Keychain? (y/N) ${NC}"
            read -k 1 save_key
            if [[ "$save_key" == "y" ]]; then
                security add-generic-password -a "$USER" -s "$DMG_NAME" -w "$passphrase" -U
                echo -e "\n${GREEN}Passphrase saved to Keychain.${NC}"
            fi
        else
            echo -e "${RED}Failed to unlock DMG (Status: $hdi_status).${NC}"
            echo -e "${RED}Please ensure the passphrase is correct.${NC}"
            return 1
        fi
    fi

    if [[ $hdi_status -eq 0 && -d "$MOUNT_POINT" ]]; then
        echo -e "${GREEN}Keystone ready at $MOUNT_POINT${NC}"
        return 0
    else
        return 1
    fi
}

unmount_dmg() {
    if [[ -d "$MOUNT_POINT" ]]; then
        hdiutil detach "$MOUNT_POINT" -quiet
    fi
}

# --- Menu Actions ---

list_keys() {
    if ! mount_dmg; then 
        echo -e "${RED}Mount failed. Cannot list keys.${NC}"
        wait_for_key
        return
    fi
    
    echo -e "${CYAN}Accessing $MOUNT_POINT...${NC}"
    sleep 0.1
    
    if [[ ! -d "$MOUNT_POINT" ]]; then
        echo -e "${RED}Error: Mount point $MOUNT_POINT vanished!${NC}"
        wait_for_key
        return
    fi

    echo -e "${BOLD}Stored Keys in Keystone:${NC}"
    
    local keys=("$MOUNT_POINT"/(id_*|*_id_*).pub(N))
    if (( ${#keys} == 0 )); then
        echo -e "${YELLOW}No .pub keys found in $MOUNT_POINT.${NC}"
        echo -e "Use Option [2] to pack your local ~/.ssh/ keys into Keystone."
    else
        for key in $keys; do
            echo -e "  [${GREEN}🔑${NC}] $(basename "$key" | sed 's/\.pub//')"
        done
        echo -e "\n${CYAN}Found ${#keys} key(s).${NC}"
    fi
    wait_for_key
}

pack_keys() {
    echo -e "${YELLOW}Packing local keys (searching for 'id_*' or '*_id_*')...${NC}"
    
    if ! mount_dmg; then
        echo -e "${RED}Mount failed. Cannot pack keys.${NC}"
        wait_for_key
        return
    fi

    # Explicitly find both private and public keys
    local local_keys=($HOME/.ssh/(id_*|*_id_*)(N))
    if (( ${#local_keys} == 0 )); then
        echo -e "${RED}No local keys found in $HOME/.ssh/ matching 'id_*' or '*_id_*'.${NC}"
        unmount_dmg
        wait_for_key
        return
    fi

    echo -e "${CYAN}Found ${#local_keys} local key files to pack.${NC}"
    local packed=0
    local skipped=0
    for key in $local_keys; do
        local filename=$(basename "$key")
        local target="$MOUNT_POINT/$filename"
        if [[ -f "$target" ]]; then
            echo -e "  [${YELLOW}○${NC}] Skipping $filename (already in Keystone)"
            ((skipped++))
        else
            echo -ne "  [${CYAN}→${NC}] Packing $filename... "
            if cp "$key" "$target"; then
                echo -e "${GREEN}Done${NC}"
                ((packed++))
            else
                echo -e "${RED}Failed${NC}"
            fi
        fi
    done

    echo -e "\n${GREEN}Success: $packed packed, $skipped already present.${NC}"
    unmount_dmg
    wait_for_key
}

restore_keys() {
    if ! mount_dmg; then
        echo -e "${RED}Mount failed. Cannot restore keys.${NC}"
        wait_for_key
        return
    fi
    
    echo -e "${YELLOW}Restoring keys to $HOME/.ssh/...${NC}"
    mkdir -p ~/.ssh
    
    local keys=("$MOUNT_POINT"/(id_*|*_id_*)(N))
    if (( ${#keys} == 0 )); then
        echo -e "${YELLOW}No keys found in Keystone to restore.${NC}"
        unmount_dmg
        wait_for_key
        return
    fi

    local restored=0
    local skipped=0
    for key in $keys; do
        local filename=$(basename "$key")
        local target="$HOME/.ssh/$filename"
        if [[ -f "$target" ]]; then
            echo -e "  [${YELLOW}○${NC}] Skipping $filename (already exists locally)"
            ((skipped++))
        else
            echo -ne "  [${CYAN}→${NC}] Restoring $filename... "
            if cp "$key" "$target"; then
                chmod $([[ "$filename" == *.pub ]] && echo 644 || echo 600) "$target"
                echo -e "${GREEN}Done${NC}"
                ((restored++))
            else
                echo -e "${RED}Failed${NC}"
            fi
        fi
    done

    # Update config_local
    echo -e "${CYAN}Updating .ssh/config_local...${NC}"
    CONFIG_LOCAL="$HOME/.ssh/config_local"
    echo "Host *" > "$CONFIG_LOCAL"
    # Update config for ALL keys
    for key in ~/.ssh/(id_*|*_id_*)(N); do
        if [[ -f "$key" && ! "$key" == *.pub ]]; then
            echo "  IdentityFile $key" >> "$CONFIG_LOCAL"
        fi
    done

    echo -e "\n${GREEN}Restoration complete: $restored restored, $skipped skipped.${NC}"
    unmount_dmg
    wait_for_key
}

remove_keys() {
    if ! mount_dmg; then
        echo -e "${RED}Mount failed. Cannot wipe keys.${NC}"
        wait_for_key
        return
    fi
    echo -e "\n${RED}${BOLD}⚠️  DANGER: WIPE KEYSTONE STORE${NC}"
    echo -e "${RED}This will permanently delete ALL keys stored in your encrypted DMG.${NC}"
    echo -e "${RED}This action is irreversible and does not affect local keys in ~/.ssh/.${NC}"
    echo -ne "\n${YELLOW}Type ${BOLD}WIPE${NC}${YELLOW} to confirm: ${NC}"
    read confirmation
    if [[ "$confirmation" == "WIPE" ]]; then
        echo -e "${YELLOW}Wiping stored keys...${NC}"
        rm -f "$MOUNT_POINT"/*
        echo -e "${GREEN}Keystone store has been wiped.${NC}"
    else
        echo -e "${BLUE}Wipe cancelled.${NC}"
    fi
    unmount_dmg
    wait_for_key
}

# --- Argument Parsing ---

# Load zparseopts if possible
zmodload zsh/zparseopts 2>/dev/null || true

# Check if zparseopts is available
if type zparseopts >/dev/null 2>&1; then
    zparseopts -D -E \
        h=help -help=help \
        -install=install \
        -remove=remove \
        -list=list \
        -pack=pack \
        -restore=restore \
        -wipe=wipe
else
    # Fallback for environments without zparseopts
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help) help=1; shift ;;
            --install) install=1; shift ;;
            --remove) remove=1; shift ;;
            --list) list=1; shift ;;
            --pack) pack=1; shift ;;
            --restore) restore=1; shift ;;
            --wipe) wipe=1; shift ;;
            *) shift ;;
        esac
    done
fi

if [[ -n "$help" ]]; then print_help; exit 0; fi
if [[ -n "$install" ]]; then install_keystone; fi
if [[ -n "$remove" ]]; then remove_keystone; fi

# CLI Mode Execution
if [[ -n "$list" || -n "$pack" || -n "$restore" || -n "$wipe" ]]; then
    export CLI_MODE=1
    [[ -n "$list" ]] && list_keys
    [[ -n "$pack" ]] && pack_keys
    [[ -n "$restore" ]] && restore_keys
    [[ -n "$wipe" ]] && remove_keys
    exit 0
fi

# --- Main Interactive Loop ---

FIRST_RUN=1
while true; do
    print_header
    check_status

    # Proactive offer to create DMG if missing on launch
    if [[ $FIRST_RUN -eq 1 && ! -f "$DMG_PATH" ]]; then
        echo -e "${YELLOW}Welcome! It looks like you haven't created your Keystone DMG yet.${NC}"
        echo -ne "${CYAN}Would you like to create it now and pack your local keys? (y/N) ${NC}"
        read -k 1 init_choice
        echo ""
        if [[ "$init_choice" == "y" ]]; then
            pack_keys
            FIRST_RUN=0
            continue
        fi
    fi
    FIRST_RUN=0

    echo -e "${BOLD}Actions:${NC}"
    echo -e "  [${CYAN}1${NC}] List stored keys"
    echo -e "  [${CYAN}2${NC}] Pack local keys to iCloud"
    echo -e "  [${CYAN}3${NC}] Restore keys to this device"
    echo -e "  [${CYAN}4${NC}] Wipe stored keys"
    echo -e "  [${CYAN}5${NC}] Exit"
    echo ""
    read -k 1 -s "choice?Select an option: "

    case $choice in
        1) list_keys ;;
        2) pack_keys ;;
        3) restore_keys ;;
        4) remove_keys ;;
        5) exit 0 ;;
    esac
done
