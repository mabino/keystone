#!/usr/bin/env zsh

# Capture script source path as early as possible
SOURCE_FILE="${(%):-%x}"

# Keystone: Private Key Manager
# https://github.com/mabino/keystone

# Colors
export BLUE='\033[0;34m'
export GREEN='\033[0;32m'
export RED='\033[0;31m'
export YELLOW='\033[1;33m'
export CYAN='\033[0;36m'
export NC='\033[0m' # No Color
export BOLD='\033[1m'

ICLOUD_PATH="$HOME/Library/Mobile Documents/com~apple~CloudDocs"
DMG_NAME="keystone.dmg"
DMG_PATH="$ICLOUD_PATH/$DMG_NAME"
MOUNT_POINT="/Volumes/Keystone"
INSTALL_PATH="${XDG_BIN_HOME:-$HOME/.local/bin}/keystone"

# --- Utility Functions ---

print_help() {
    echo -e "${CYAN}${BOLD}🔑 KEYSTONE: Private Key Manager${NC}"
    echo -e "Usage: keystone [options]"
    echo ""
    echo -e "${BOLD}Options:${NC}"
    echo -e "  -h, --help      Show this help message"
    echo -e "  --install       Install keystone to ~/.local/bin"
    echo -e "  --remove        Uninstall keystone from ~/.local/bin"
    echo -e "  --list          List stored keys"
    echo -e "  --pack          Pack local keys to iCloud"
    echo -e "  --restore       Restore keys to this device"
    echo -e "  --wipe          Wipe stored keys (Dangerous!)"
    echo ""
    echo -e "${BOLD}Examples:${NC}"
    echo -e "  keystone        (Launch interactive menu)"
    echo -e "  keystone --pack (Run pack and exit)"
}

install_keystone() {
    echo -e "${YELLOW}Installing Keystone...${NC}"
    mkdir -p "$(dirname "$INSTALL_PATH")" || { echo -e "${RED}Error: Failed to create directory $(dirname "$INSTALL_PATH")${NC}"; exit 1; }
    
    if [[ -f "$SOURCE_FILE" ]]; then
        cp "$SOURCE_FILE" "$INSTALL_PATH" || { echo -e "${RED}Error: Failed to copy $SOURCE_FILE to $INSTALL_PATH${NC}"; exit 1; }
    else
        # Piped installation fallback (e.g., curl | zsh)
        echo -e "${YELLOW}Installing from GitHub...${NC}"
        if command -v curl >/dev/null; then
            curl -fsSL https://raw.githubusercontent.com/mabino/keystone/main/keystone -o "$INSTALL_PATH" || { echo -e "${RED}Error: Failed to download Keystone${NC}"; exit 1; }
        elif command -v wget >/dev/null; then
            wget -qO "$INSTALL_PATH" https://raw.githubusercontent.com/mabino/keystone/main/keystone || { echo -e "${RED}Error: Failed to download Keystone${NC}"; exit 1; }
        else
            echo -e "${RED}Error: Cannot install from pipe without curl or wget.${NC}"
            exit 1
        fi
    fi

    chmod +x "$INSTALL_PATH" || { echo -e "${RED}Error: Failed to make $INSTALL_PATH executable${NC}"; exit 1; }
    echo -e "${GREEN}Keystone installed to $INSTALL_PATH${NC}"
    exit 0
}

remove_keystone() {
    echo -e "${RED}Uninstalling Keystone...${NC}"
    rm -f "$INSTALL_PATH"
    echo -e "${GREEN}Keystone removed.${NC}"
    exit 0
}

print_header() {
    clear
    echo -e "${CYAN}${BOLD}🔑 KEYSTONE: Private Key Manager${NC}"
    echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}\n"
}

check_status() {
    echo -e "${BOLD}Current Status:${NC}"
    
    # 1. iCloud Drive
    if [[ -d "$ICLOUD_PATH" ]]; then
        echo -e "  [${GREEN}✓${NC}] iCloud Drive: ${GREEN}Mounted${NC}"
    else
        echo -e "  [${RED}✗${NC}] iCloud Drive: ${RED}Not Found${NC}"
    fi

    # 2. Encrypted DMG
    if [[ -f "$DMG_PATH" ]]; then
        echo -e "  [${GREEN}✓${NC}] Encrypted DMG: ${GREEN}Detected${NC} ($DMG_NAME)"
    else
        echo -e "  [${YELLOW}!${NC}] Encrypted DMG: ${YELLOW}Missing${NC} (Will be created on pack)"
    fi

    # 3. Keychain Status
    if security find-generic-password -l "$DMG_NAME" > /dev/null 2>&1; then
        echo -e "  [${GREEN}✓${NC}] Apple Keychain: ${GREEN}Passphrase Found${NC}"
    else
        echo -e "  [${YELLOW}!${NC}] Apple Keychain: ${YELLOW}Passphrase Not Stored${NC}"
    fi

    # 4. Mount Status
    if [[ -d "$MOUNT_POINT" ]]; then
        echo -e "  [${GREEN}✓${NC}] DMG State: ${GREEN}Unlocked & Mounted${NC}"
    else
        echo -e "  [${YELLOW}○${NC}] DMG State: ${YELLOW}Locked${NC}"
    fi
    echo ""
}

# --- Authentication ---

authenticate() {
    echo -e "${YELLOW}Authenticating with Touch ID...${NC}"
    swift -e '
import LocalAuthentication
let context = LAContext()
var error: NSError?
if context.canEvaluatePolicy(.deviceOwnerAuthenticationWithBiometrics, error: &error) {
    let semaphore = DispatchSemaphore(value: 0)
    var success = false
    context.evaluatePolicy(.deviceOwnerAuthenticationWithBiometrics, localizedReason: "Unlock Keystone") { (s, e) in
        success = s
        semaphore.signal()
    }
    semaphore.wait()
    exit(success ? 0 : 1)
} else {
    exit(0) 
}'
    local AUTH_STATUS=$?
    if [[ $AUTH_STATUS -ne 0 ]]; then
        echo -e "${RED}Authentication failed.${NC}"
        return 1
    fi
    return 0
}

mount_dmg() {
    if [[ -d "$MOUNT_POINT" ]]; then return 0; fi
    if ! authenticate; then return 1; fi

    echo -e "${YELLOW}Unlocking Keystone DMG...${NC}"
    if hdiutil attach -keychain "$DMG_PATH" -mountpoint "$MOUNT_POINT"; then
        echo -e "${GREEN}Keystone unlocked!${NC}"
        return 0
    else
        echo -e "${RED}Failed to unlock DMG.${NC}"
        return 1
    fi
}

unmount_dmg() {
    if [[ -d "$MOUNT_POINT" ]]; then
        hdiutil detach "$MOUNT_POINT" -quiet
    fi
}

# --- Menu Actions ---

list_keys() {
    if ! mount_dmg; then return; fi
    echo -e "${BOLD}Stored Keys in Keystone:${NC}"
    ls -1 "$MOUNT_POINT"/*.pub 2>/dev/null | xargs -n1 basename | sed 's/\.pub//' || echo "No keys found."
    [[ -z "$CLI_MODE" ]] && read -k 1 -s "?Press any key to return..."
}

pack_keys() {
    echo -e "${YELLOW}Packing local keys (~/.ssh/id_*)...${NC}"
    if [[ ! -f "$DMG_PATH" ]]; then
        mkdir -p /tmp/keystone_tmp
        hdiutil create -size 10m -fs HFS+ -volname Keystone -encryption AES-256 -srcfolder /tmp/keystone_tmp "$DMG_PATH"
        rm -rf /tmp/keystone_tmp
    fi
    if ! mount_dmg; then return; fi
    cp ~/.ssh/id_* "$MOUNT_POINT/" 2>/dev/null
    echo -e "${GREEN}Keys packed to iCloud!${NC}"
    unmount_dmg
    [[ -z "$CLI_MODE" ]] && read -k 1 -s "?Press any key to return..."
}

restore_keys() {
    if ! mount_dmg; then return; fi
    echo -e "${YELLOW}Restoring keys to ~/.ssh/...${NC}"
    mkdir -p ~/.ssh
    cp "$MOUNT_POINT"/id_* ~/.ssh/ 2>/dev/null
    chmod 600 ~/.ssh/id_* 2>/dev/null
    chmod 644 ~/.ssh/id_*.pub 2>/dev/null
    CONFIG_LOCAL="$HOME/.ssh/config_local"
    echo "Host *" > "$CONFIG_LOCAL"
    for key in ~/.ssh/id_ed25519 ~/.ssh/id_rsa; do
        if [[ -f "$key" ]]; then
            echo "  IdentityFile $key" >> "$CONFIG_LOCAL"
        fi
    done
    echo -e "${GREEN}Keys restored and config_local updated!${NC}"
    unmount_dmg
    [[ -z "$CLI_MODE" ]] && read -k 1 -s "?Press any key to return..."
}

remove_keys() {
    if ! mount_dmg; then return; fi
    echo -e "${RED}Are you sure you want to wipe Keystone? (y/N)${NC}"
    read -k 1 confirm
    if [[ "$confirm" == "y" ]]; then
        rm -f "$MOUNT_POINT"/*
        echo -e "\n${GREEN}Keystone wiped.${NC}"
    fi
    unmount_dmg
    [[ -z "$CLI_MODE" ]] && read -k 1 -s "?Press any key to return..."
}

# --- Argument Parsing ---

# Load zparseopts if possible
zmodload zsh/zparseopts 2>/dev/null || true

# Check if zparseopts is available
if type zparseopts >/dev/null 2>&1; then
    zparseopts -D -E \
        h=help -help=help \
        -install=install \
        -remove=remove \
        -list=list \
        -pack=pack \
        -restore=restore \
        -wipe=wipe
else
    # Fallback for environments without zparseopts
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help) help=1; shift ;;
            --install) install=1; shift ;;
            --remove) remove=1; shift ;;
            --list) list=1; shift ;;
            --pack) pack=1; shift ;;
            --restore) restore=1; shift ;;
            --wipe) wipe=1; shift ;;
            *) shift ;;
        esac
    done
fi

if [[ -n "$help" ]]; then print_help; exit 0; fi
if [[ -n "$install" ]]; then install_keystone; fi
if [[ -n "$remove" ]]; then remove_keystone; fi

# CLI Mode Execution
if [[ -n "$list" || -n "$pack" || -n "$restore" || -n "$wipe" ]]; then
    export CLI_MODE=1
    [[ -n "$list" ]] && list_keys
    [[ -n "$pack" ]] && pack_keys
    [[ -n "$restore" ]] && restore_keys
    [[ -n "$wipe" ]] && remove_keys
    exit 0
fi

# --- Main Interactive Loop ---

while true; do
    print_header
    check_status
    echo -e "${BOLD}Actions:${NC}"
    echo -e "  [${CYAN}1${NC}] List stored keys"
    echo -e "  [${CYAN}2${NC}] Pack local keys to iCloud"
    echo -e "  [${CYAN}3${NC}] Restore keys to this device"
    echo -e "  [${CYAN}4${NC}] Wipe stored keys"
    echo -e "  [${CYAN}5${NC}] Exit"
    echo ""
    read -k 1 -s "choice?Select an option: "

    case $choice in
        1) list_keys ;;
        2) pack_keys ;;
        3) restore_keys ;;
        4) remove_keys ;;
        5) exit 0 ;;
    esac
done
